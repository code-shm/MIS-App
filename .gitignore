# Data artifacts (regenerated by the pipeline — do not commit multi-GB files)
data/raw/*.zip
data/raw/*.csv
data/raw/*.parquet
data/processed/*.parquet
data/processed/*.csv
data/outputs/*.parquet
data/outputs/*.csv
*.log
!data/**/.gitkeep
# Keep the small precomputed MIS tables so the deployed dashboard & CI refresh
# retain the industry-benchmark panel without re-running the 17M-row pass.
!data/outputs/mis_industry_monthly.parquet
!data/outputs/mis_company_benchmark.parquet

# Internal build intermediate (published as an Artifact instead)
dashboards/html/_artifact_body.html

# Power BI row-level fact is 17 MB - regenerate with scripts/export_powerbi.py.
# Comment out the next line to make the repo turnkey for Power BI.
dashboards/powerbi/data/fact_complaints.csv

# Models
models/*.joblib
models/*.pkl

# Credentials — never commit
*.json
!config/*.json
!dashboards/**/*.json
service-account*.json
.env

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/

# Reports (regenerated by src.report)
reports/figures/*.png
reports/*.pdf

# Node
node_modules/
npm-debug.log*

# OS
.DS_Store
Thumbs.db
